@{
    Layout = "_HospitalLayout";
}
@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        @TempData["Success"]
    </div>
}
<form asp-controller="Dashboard" asp-action="PharmacistRegistration" method="post">
    <input name="Username" placeholder="Enter Your Username" class="form-control" />
    <input name="Password" type="password" placeholder="Enter your Password" class="form-control mt-2" />
 <input name="Email" placeholder="Enter your Email" class="form-control" />
  <input name="Phone" placeholder="Enter Phone number" class="form-control" />
 <input name="Gender" placeholder="Enter Gender" class="form-control" />
    <input name="Address" placeholder="Enter Address" class="form-control" />
    <button type="submit" class="btn btn-primary mt-2">Submit</button>
</form>

@if (ViewBag.Error != null)
{
    <p class="text-danger">@ViewBag.Error</p>
}
